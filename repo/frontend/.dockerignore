# Prevent host dependencies/build artifacts from entering the image
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build/test outputs
dist
coverage
playwright-report
test-results
.vitest

# Local env/editor/git artifacts
.env
.env.*
*.log
.git
.gitignore
.DS_Store
.vscode
.idea

# Optional local caches
.cache

# Test-only assets not needed for production image build
e2e
unit_tests
playwright.config.ts
vitest.config.ts
